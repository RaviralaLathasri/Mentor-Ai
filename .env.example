# Backend configuration
DATABASE_URL=sqlite:///./mentor_ai.db
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional LLM provider settings
OPENAI_API_KEY=
OPENAI_API_BASE=
