# Backend configuration
DATABASE_URL=sqlite:///./mentor_ai.db
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:3000

# Optional LLM provider settings
OPENAI_API_KEY=
OPENAI_API_BASE=
# For OpenRouter, "openrouter/auto" is recommended.
OPENAI_API_MODEL=openrouter/auto
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=Mentor AI

# Audio Interview System (Redis + STT + TTS)
# Interview store backend:
# - "redis" (recommended for production)
# - "memory" (dev-only fallback; process-local, cleared on restart)
# If left blank/unset, the backend will auto-detect Redis and fall back to memory if Redis is unavailable.
INTERVIEW_STORE_BACKEND=
# Windows dev: you can start a local Redis with `powershell -ExecutionPolicy Bypass -File scripts\\dev_redis.ps1`.
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=1.0
REDIS_SOCKET_TIMEOUT=2.0
INTERVIEW_SESSION_TTL_SECONDS=7200

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_API_BASE=https://api.elevenlabs.io/v1

# Groq Whisper (STT)
GROQ_API_KEY=
GROQ_API_BASE=https://api.groq.com/openai/v1
GROQ_WHISPER_MODEL=whisper-large-v3

# STT chunking (controls how quickly transcripts appear; smaller = more API calls)
STT_SEGMENT_SECONDS=1.2
